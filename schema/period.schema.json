{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oble.dev/schema/period.schema.json",
  "title": "OBLE Period",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "book_id",
    "name",
    "start_date",
    "end_date",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "start_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "end_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "soft_closed",
        "closed",
        "locked"
      ]
    },
    "period_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "year": {
      "type": "integer"
    },
    "period_type": {
      "type": "string"
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
