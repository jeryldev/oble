{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oble.dev/schema/book.schema.json",
  "title": "OBLE Book",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "base_currency",
    "decimal_places"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "base_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "decimal_places": {
      "type": "integer",
      "minimum": 0,
      "maximum": 12
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "fiscal_year_start": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
