{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oble.dev/schema/comparative-statement-result.schema.json",
  "title": "OBLE Comparative Statement Result Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "packet_kind",
    "book_id",
    "decimal_places",
    "current_total_debits",
    "current_total_credits",
    "prior_total_debits",
    "prior_total_credits",
    "rows"
  ],
  "properties": {
    "packet_kind": {
      "type": "string",
      "enum": [
        "trial_balance_comparative",
        "trial_balance_movement_comparative",
        "income_statement_comparative",
        "balance_sheet_comparative"
      ]
    },
    "book_id": { "type": "string", "minLength": 1 },
    "current_as_of_date": { "type": "string", "minLength": 1 },
    "prior_as_of_date": { "type": "string", "minLength": 1 },
    "current_start_date": { "type": "string", "minLength": 1 },
    "current_end_date": { "type": "string", "minLength": 1 },
    "prior_start_date": { "type": "string", "minLength": 1 },
    "prior_end_date": { "type": "string", "minLength": 1 },
    "fy_start_date": { "type": "string", "minLength": 1 },
    "decimal_places": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "current_total_debits": { "type": "string", "minLength": 1 },
    "current_total_credits": { "type": "string", "minLength": 1 },
    "prior_total_debits": { "type": "string", "minLength": 1 },
    "prior_total_credits": { "type": "string", "minLength": 1 },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "account_id",
          "account_number",
          "account_name",
          "account_type",
          "current_debit",
          "current_credit",
          "prior_debit",
          "prior_credit",
          "variance_debit",
          "variance_credit"
        ],
        "properties": {
          "account_id": { "type": "string", "minLength": 1 },
          "account_number": { "type": "string" },
          "account_name": { "type": "string" },
          "account_type": { "type": "string", "minLength": 1 },
          "current_debit": { "type": "string", "minLength": 1 },
          "current_credit": { "type": "string", "minLength": 1 },
          "prior_debit": { "type": "string", "minLength": 1 },
          "prior_credit": { "type": "string", "minLength": 1 },
          "variance_debit": { "type": "string", "minLength": 1 },
          "variance_credit": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
