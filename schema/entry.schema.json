{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oble.dev/schema/entry.schema.json",
  "title": "OBLE Entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "book_id",
    "period_id",
    "status",
    "transaction_date",
    "posting_date",
    "lines"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "book_id": {
      "type": "string",
      "minLength": 1
    },
    "period_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "posted",
        "void",
        "reversed"
      ]
    },
    "transaction_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "posting_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "document_number": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "entry_type": {
      "type": "string"
    },
    "reverses_entry_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ]
    },
    "lines": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/line"
      }
    }
  },
  "$defs": {
    "amountString": {
      "type": "string",
      "pattern": "^-?\\d+(\\.\\d+)?$"
    },
    "line": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "line_number",
        "account_id",
        "debit_amount",
        "credit_amount"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "entry_id": {
          "type": "string",
          "minLength": 1
        },
        "line_number": {
          "type": "integer",
          "minimum": 1
        },
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "debit_amount": {
          "$ref": "#/$defs/amountString"
        },
        "credit_amount": {
          "$ref": "#/$defs/amountString"
        },
        "transaction_currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "fx_rate": {
          "$ref": "#/$defs/amountString"
        },
        "base_debit_amount": {
          "$ref": "#/$defs/amountString"
        },
        "base_credit_amount": {
          "$ref": "#/$defs/amountString"
        },
        "description": {
          "type": "string"
        },
        "counterparty_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    }
  }
}
