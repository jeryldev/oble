{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oble.dev/schema/integrity-summary-result.schema.json",
  "title": "OBLE Integrity Summary Result Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "packet_kind",
    "book_id",
    "passed",
    "errors",
    "warnings",
    "entries_checked",
    "accounts_checked",
    "periods_checked"
  ],
  "properties": {
    "packet_kind": { "type": "string", "enum": ["integrity_summary"] },
    "book_id": { "type": "string", "minLength": 1 },
    "passed": { "type": "boolean" },
    "errors": { "type": "integer", "minimum": 0 },
    "warnings": { "type": "integer", "minimum": 0 },
    "entries_checked": { "type": "integer", "minimum": 0 },
    "accounts_checked": { "type": "integer", "minimum": 0 },
    "periods_checked": { "type": "integer", "minimum": 0 }
  }
}
